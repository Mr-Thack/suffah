{
  "name": "suffah-display",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev --proxy 5173 -- vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "wrangler d1 execute suffahdb --local --file=./seed.sql",
    "deploy": "vite build && wrangler pages deploy .svelte-kit/cloudflare"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^4.90.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "csv-parse": "^6.2.1"
  }
}
